<VirtualHost *:8000>
    ServerName dev-inlislite4.perpusnas.go.id
    ServerAlias dev-inlislite4.perpusnas.go.id
    ServerAlias 192.168.2.9    # Tambahkan ini
    DocumentRoot /var/www/html/backend-inlislite/public

    <Directory /var/www/html/backend/public>
        AllowOverride All
        Require all granted
    </Directory>

    ErrorLog ${APACHE_LOG_DIR}/laravel_error.log
    CustomLog ${APACHE_LOG_DIR}/laravel_access.log combined
</VirtualHost>